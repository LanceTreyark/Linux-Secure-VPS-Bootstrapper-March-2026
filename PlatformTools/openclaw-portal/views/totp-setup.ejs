<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpenClaw — Set Up Two-Factor Authentication</title>
  <link rel="stylesheet" href="/css/login.css">
  <style>
    .setup-section { margin-bottom: 24px; }
    .qr-container {
      text-align: center;
      padding: 20px;
      background: #fff;
      border-radius: 12px;
      display: inline-block;
      margin: 16px auto;
    }
    .qr-container img { width: 200px; height: 200px; display: block; }
    .secret-key {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 14px;
      letter-spacing: 2px;
      background: var(--input-bg);
      border: 1px solid var(--input-border);
      border-radius: var(--radius-sm);
      padding: 12px 16px;
      color: #a5b4fc;
      text-align: center;
      word-break: break-all;
      user-select: all;
      cursor: pointer;
    }
    .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: linear-gradient(135deg, #6366f1, #7c3aed);
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      margin-right: 8px;
      flex-shrink: 0;
    }
    .step {
      display: flex;
      align-items: flex-start;
      gap: 4px;
      margin-bottom: 12px;
      color: var(--text-dim);
      font-size: 14px;
      line-height: 1.5;
    }
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 600;
    }
    .status-enabled {
      background: rgba(34, 197, 94, 0.15);
      color: #22c55e;
      border: 1px solid rgba(34, 197, 94, 0.25);
    }
    .status-disabled {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .divider {
      border: none;
      border-top: 1px solid var(--card-border);
      margin: 24px 0;
    }
    .btn-danger {
      background: linear-gradient(135deg, #dc2626, #b91c1c);
    }
    .btn-danger:hover {
      box-shadow: 0 8px 24px rgba(220, 38, 38, 0.3);
    }
    .back-link {
      display: block;
      text-align: center;
      margin-top: 16px;
      color: var(--text-dim);
      text-decoration: none;
      font-size: 13px;
    }
    .back-link:hover { color: var(--accent); }
  </style>
</head>
<body>
  <div class="bg-grid"></div>
  <div class="container" style="max-width: 480px;">
    <div class="login-card">
      <div class="logo-section">
        <div class="logo-icon">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="22" stroke="url(#grad)" stroke-width="2.5" fill="none"/>
            <rect x="14" y="18" width="20" height="16" rx="3" fill="url(#grad)" opacity="0.8"/>
            <path d="M18 18v-4a6 6 0 0 1 12 0v4" stroke="url(#grad)" stroke-width="2.5" fill="none"/>
            <circle cx="24" cy="27" r="2.5" fill="#0a0a0f"/>
            <defs>
              <linearGradient id="grad" x1="0" y1="0" x2="48" y2="48">
                <stop offset="0%" stop-color="#6366f1"/>
                <stop offset="100%" stop-color="#8b5cf6"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h1>Two-Factor Auth</h1>
        <p class="subtitle">
          <% if (totpEnabled) { %>
            <span class="status-badge status-enabled">&#x2713; ENABLED</span>
          <% } else { %>
            <span class="status-badge status-disabled">&#x2717; NOT ENABLED</span>
          <% } %>
        </p>
      </div>

      <% if (error) { %>
        <div class="error-msg">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm-.75 4a.75.75 0 0 1 1.5 0v3a.75.75 0 0 1-1.5 0V5zm.75 6.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <% if (!totpEnabled) { %>
        <div class="setup-section">
          <div class="step"><span class="step-number">1</span> Install an authenticator app (Google Authenticator, Authy, 1Password, etc.)</div>
          <div class="step"><span class="step-number">2</span> Scan this QR code with your authenticator app:</div>

          <div style="text-align:center">
            <div class="qr-container">
              <img src="<%= qrDataUrl %>" alt="TOTP QR Code">
            </div>
          </div>

          <div class="step"><span class="step-number">3</span> Or enter this secret key manually:</div>
          <div class="secret-key" title="Click to select"><%= secret %></div>

          <div class="step" style="margin-top:16px"><span class="step-number">4</span> Enter the 6-digit code from your app to verify:</div>
        </div>

        <form action="/2fa/enable" method="POST" autocomplete="off">
          <div class="input-group">
            <label for="code">Authenticator Code</label>
            <div class="input-wrapper">
              <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input type="text" id="code" name="code" placeholder="000 000" required autofocus
                     maxlength="7" inputmode="numeric" pattern="[0-9\s]{6,7}"
                     style="text-align:center; font-size:1.25rem; letter-spacing:0.4rem; font-weight:700">
            </div>
          </div>

          <button type="submit" class="btn-login">
            <span>Enable 2FA</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </button>
        </form>
      <% } else { %>
        <div class="setup-section">
          <p style="color:var(--text-dim); font-size:14px; line-height:1.6; text-align:center">
            Two-factor authentication is active on your account. Every login will require a code from your authenticator app.
          </p>
        </div>

        <hr class="divider">

        <p style="color:var(--text-dim); font-size:13px; margin-bottom:12px; text-align:center">
          To disable 2FA, enter your password:
        </p>

        <form action="/2fa/disable" method="POST" autocomplete="off">
          <div class="input-group">
            <label for="password">Current Password</label>
            <div class="input-wrapper">
              <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>
          </div>

          <button type="submit" class="btn-login btn-danger">
            <span>Disable 2FA</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </form>
      <% } %>

      <a href="/" class="back-link">&larr; Back to dashboard</a>

      <div class="footer-text">
        Secured with TOTP &bull; <span class="version">v1.0</span>
      </div>
    </div>
  </div>
</body>
</html>
